# ══════════════════════════════════════════════════════════════════════════════
# Canada This Month (CTM) September 2018 — Immigration Threat Shiny App
#
# 4 Visualizations:
#   1. Threat by Party        — bar chart, A6
#   2. Threat by Province     — choropleth map, PROV
#   3. Media & Threat         — bar chart, RSH11 (news exposure)
#   4. Threat by Ideology     — bar chart, VIDO
#
# Sidebar filters: party, ideology, province, gender, age group
# ══════════════════════════════════════════════════════════════════════════════
# ── 0. Packages ────────────────────────────────────────────────────────────────
pkgs <- c("shiny","shinydashboard","leaflet","haven",
"dplyr","tidyr","scales","ggplot2","sf","rnaturalearth","rnaturalearthdata")
new  <- pkgs[!pkgs %in% installed.packages()[,"Package"]]
if (length(new)) install.packages(new, repos = "https://cloud.r-project.org")
invisible(lapply(pkgs, library, character.only = TRUE))
# ── 1. Load data ───────────────────────────────────────────────────────────────
raw <- haven::read_sav("IRG1230_CTM1809_181003_wt (CLEAN).sav")
# ── 2. Build threat_index from IMM1–IMM6 ──────────────────────────────────────
# Higher score = more perceived immigration threat (0–100 scale)
raw <- raw %>%
dplyr::mutate(
imm1_r = dplyr::case_when(IMM1 %in% 1:5 ~ as.numeric(IMM1),       TRUE ~ NA_real_),
imm2_r = dplyr::case_when(IMM2 %in% 1:5 ~ 6 - as.numeric(IMM2),   TRUE ~ NA_real_),
imm3_r = dplyr::case_when(IMM3 %in% 1:2 ~ 3 - as.numeric(IMM3),   TRUE ~ NA_real_),
imm4_r = dplyr::case_when(IMM4 %in% 1:4 ~ as.numeric(IMM4),       TRUE ~ NA_real_),
imm5_r = dplyr::case_when(IMM5==2~3, IMM5==3~2, IMM5==1~1,        TRUE ~ NA_real_),
imm6_r = dplyr::case_when(IMM6 %in% 1:2 ~ 3 - as.numeric(IMM6),   TRUE ~ NA_real_),
threat_raw   = rowMeans(dplyr::across(c(imm1_r,imm2_r,imm3_r,
imm4_r,imm5_r,imm6_r)), na.rm=TRUE),
threat_index = scales::rescale(threat_raw, to=c(0,100))
)
# ── 3. Recode demographic & filter variables ───────────────────────────────────
MISSING <- c(88, 98, 99)
raw <- raw %>%
dplyr::mutate(
# Party
party = dplyr::case_when(
A6 == 1 ~ "Conservative",
A6 == 2 ~ "Liberal",
A6 == 3 ~ "NDP",
A6 == 4 ~ "Bloc Quebecois",
A6 == 5 ~ "Green",
A6 == 6 ~ "People's Party",
TRUE    ~ NA_character_
),
# Ideology (VIDO: 1=far left ... 5=far right)
ideology = dplyr::case_when(
as.numeric(VIDO) == 1 ~ "Far Left",
as.numeric(VIDO) == 2 ~ "Centre-Left",
as.numeric(VIDO) == 3 ~ "Centre",
as.numeric(VIDO) == 4 ~ "Centre-Right",
as.numeric(VIDO) == 5 ~ "Far Right",
TRUE                  ~ NA_character_
),
ideology = factor(ideology,
levels=c("Far Left","Centre-Left","Centre",
"Centre-Right","Far Right")),
# Province
prov_name = dplyr::case_when(
as.numeric(PROV) == 1  ~ "Alberta",
as.numeric(PROV) == 2  ~ "British Columbia",
as.numeric(PROV) == 3  ~ "Manitoba",
as.numeric(PROV) == 4  ~ "New Brunswick",
as.numeric(PROV) == 5  ~ "Newfoundland and Labrador",
as.numeric(PROV) == 6  ~ "Nova Scotia",
as.numeric(PROV) == 7  ~ "Ontario",
as.numeric(PROV) == 8  ~ "Prince Edward Island",
as.numeric(PROV) == 9  ~ "Quebec",
as.numeric(PROV) == 10 ~ "Saskatchewan",
as.numeric(PROV) == 11 ~ "Northwest Territories",
as.numeric(PROV) == 12 ~ "Yukon",
as.numeric(PROV) == 13 ~ "Nunavut",
TRUE                   ~ NA_character_
),
prov_abbr = dplyr::case_when(
as.numeric(PROV) == 1  ~ "AB",
as.numeric(PROV) == 2  ~ "BC",
as.numeric(PROV) == 3  ~ "MB",
as.numeric(PROV) == 4  ~ "NB",
as.numeric(PROV) == 5  ~ "NL",
as.numeric(PROV) == 6  ~ "NS",
as.numeric(PROV) == 7  ~ "ON",
as.numeric(PROV) == 8  ~ "PEI",
as.numeric(PROV) == 9  ~ "QC",
as.numeric(PROV) == 10 ~ "SK",
as.numeric(PROV) == 11 ~ "NT",
as.numeric(PROV) == 12 ~ "YT",
as.numeric(PROV) == 13 ~ "NU",
TRUE                   ~ NA_character_
),
# Gender
gender = dplyr::case_when(
as.numeric(GENDER) == 1 ~ "Male",
as.numeric(GENDER) == 2 ~ "Female",
TRUE                    ~ NA_character_
),
# Age group (AGE_COL: 1=18-24 ... 6=65+)
age_group = dplyr::case_when(
as.numeric(AGE_COL) == 1 ~ "18-24",
as.numeric(AGE_COL) == 2 ~ "25-34",
as.numeric(AGE_COL) == 3 ~ "35-44",
as.numeric(AGE_COL) == 4 ~ "45-54",
as.numeric(AGE_COL) == 5 ~ "55-64",
as.numeric(AGE_COL) == 6 ~ "65+",
TRUE                     ~ NA_character_
),
age_group = factor(age_group,
levels=c("18-24","25-34","35-44","45-54","55-64","65+")),
# Media exposure (RSH11: 1=Yes, 2=No — heard news about PM/fed gov recently)
media_label = dplyr::case_when(
as.numeric(RSH11) == 1 ~ "Exposed to\nPM/Gov News",
as.numeric(RSH11) == 2 ~ "Not Exposed to\nPM/Gov News",
TRUE                   ~ NA_character_
),
WT = as.numeric(WT)
) %>%
dplyr::filter(!is.na(threat_index), !is.na(WT))
# ══════════════════════════════════════════════════════════════════════════════
# Canada Immigration Attitudes & Voting Preferences — R Shiny App
# Dataset: IRG1230_CTM1809_181003_wt (CLEAN).sav
# Choropleth version: uses rnaturalearth province polygons
# ══════════════════════════════════════════════════════════════════════════════
# ── 0. Packages ────────────────────────────────────────────────────────────────
pkgs <- c("shiny", "shinydashboard", "leaflet", "haven",
"dplyr", "tidyr", "scales", "ggplot2", "RColorBrewer",
"sf", "rnaturalearth", "rnaturalearthdata")
new  <- pkgs[!pkgs %in% installed.packages()[,"Package"]]
if (length(new)) install.packages(new, repos = "https://cloud.r-project.org")
invisible(lapply(pkgs, library, character.only = TRUE))
# ── 1. Load data ───────────────────────────────────────────────────────────────
raw <- haven::read_sav("IRG1230_CTM1809_181003_wt (CLEAN).sav")
# ── 2. Lookup tables ───────────────────────────────────────────────────────────
prov_lookup <- data.frame(
PROV      = 1:13,
prov_name = c("Alberta","British Columbia","Manitoba","New Brunswick",
"Newfoundland and Labrador","Nova Scotia","Ontario",
"Prince Edward Island","Quebec","Saskatchewan",
"Northwest Territories","Yukon","Nunavut"),
prov_abbr = c("AB","BC","MB","NB","NL","NS","ON","PEI","QC","SK","NT","YT","NU"),
stringsAsFactors = FALSE
)
# IMM1 labels
imm1_labels <- c("1"="A very good thing",
"2"="A good thing",
"3"="Neither good nor bad",
"4"="A bad thing",
"5"="A very bad thing")
# A6 labels
vote_labels <- c("1"="Conservative","2"="Liberal","3"="NDP",
"4"="Bloc Québécois","5"="Green",
"6"="People's Party of Canada")
party_colors <- c(
"Conservative"             = "#1A4782",
"Liberal"                  = "#D71920",
"NDP"                      = "#F37021",
"Bloc Québécois"           = "#33B2CC",
"Green"                    = "#3D9B35",
"People's Party of Canada" = "#6B2D8B"
)
# ── 3. Clean & recode ──────────────────────────────────────────────────────────
df <- raw %>%
dplyr::mutate(
PROV = as.numeric(PROV),
IMM1 = as.numeric(IMM1),
A6   = as.numeric(A6),
wt   = as.numeric(wt)
) %>%
dplyr::filter(IMM1 %in% c(1, 2, 3, 4, 5)) %>%
dplyr::filter(A6 %in% 1:6) %>%
dplyr::filter(!is.na(PROV), !is.na(wt)) %>%
dplyr::mutate(
imm_label  = dplyr::recode(as.character(IMM1), !!!imm1_labels),
vote_label = dplyr::recode(as.character(A6),   !!!vote_labels)
) %>%
dplyr::left_join(prov_lookup, by = "PROV")
# ── 4. Province-level summaries ────────────────────────────────────────────────
# 4a. Weighted % per IMM1 response per province
prov_imm <- df %>%
dplyr::group_by(prov_name, prov_abbr) %>%
dplyr::summarise(
pct_pro   = sum(wt * (IMM1 %in% c(1,2)), na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
pct_vgood = sum(wt * (IMM1 == 1),        na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
pct_good  = sum(wt * (IMM1 == 2),        na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
pct_neut  = sum(wt * (IMM1 == 3),        na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
pct_bad   = sum(wt * (IMM1 == 4),        na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
pct_vbad  = sum(wt * (IMM1 == 5),        na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
pct_con   = sum(wt * (IMM1 %in% c(4,5)), na.rm=TRUE) / sum(wt, na.rm=TRUE) * 100,
n         = dplyr::n(),
.groups   = "drop"
)
# 4b. Voting share per province
prov_vote <- df %>%
dplyr::group_by(prov_name, prov_abbr, vote_label) %>%
dplyr::summarise(wt_sum = sum(wt, na.rm=TRUE), n = dplyr::n(), .groups="drop") %>%
dplyr::group_by(prov_name) %>%
dplyr::mutate(pct = wt_sum / sum(wt_sum) * 100) %>%
dplyr::ungroup()
prov_dominant <- prov_vote %>%
dplyr::group_by(prov_name, prov_abbr) %>%
dplyr::slice_max(wt_sum, n=1, with_ties=FALSE) %>%
dplyr::ungroup()
# ── 5. Load Canada province polygons ──────────────────────────────────────────
canada_sf <- rnaturalearth::ne_states(country = "Canada", returnclass = "sf")
runApp('~/Downloads/app_5.R')
runApp('~/Downloads/app_5.R')
df3 <- df3 %>%
mutate(extremism = abs(ideology - 5))
cat("Extremism summary:\n")
print(summary(df3$extremism))
# Regression 1: Combined threat index -> ideology
m_ideology <- lm(ideology ~ nativism + age + income + education, data=df3)
cat("\nRegression 1: Combined threat -> Ideology\n")
print(summary(m_ideology))
# Regression 2: Combined threat index -> extremism
m_extremism <- lm(extremism ~ nativism + age + income + education, data=df3)
cat("\nRegression 2: Combined threat -> Extremism\n")
print(summary(m_extremism))
m_domains <- lm(ideology ~ cultural_index + economic_index +
security_index + populist_index + age + income + education,
data=df3)
cat("\nRegression 3: Threat domains -> Ideology\n")
print(summary(m_domains))
m_domains <- lm(ideology ~ cultural_index + economic_index +
security_index + populist_index + age + income + education,
data=df3)
cat("\nRegression 3: Threat domains -> Ideology\n")
print(summary(m_domains))
library(broom)
library(ggplot2)
library(dplyr)
# Model 1
p1 <- broom::tidy(m_ideology, conf.int=TRUE) %>%
filter(term != "(Intercept)") %>%
mutate(sig = p.value < 0.05, model = "Model 1: Combined Threat → Ideology")
# Model 2
p2 <- broom::tidy(m_extremism, conf.int=TRUE) %>%
filter(term != "(Intercept)") %>%
mutate(sig = p.value < 0.05, model = "Model 2: Combined Threat → Extremism")
# Model 3
p3 <- broom::tidy(m_domains, conf.int=TRUE) %>%
filter(term != "(Intercept)") %>%
mutate(sig = p.value < 0.05, model = "Model 3: Threat Domains → Ideology")
# Combined plot
bind_rows(p1, p2, p3) %>%
mutate(
term = case_match(term,
"nativism"       ~ "Combined Threat Index",
"cultural_index" ~ "Cultural Threat",
"economic_index" ~ "Economic Threat",
"security_index" ~ "Security Threat",
"populist_index" ~ "Populist Threat",
"age"            ~ "Age",
"income"         ~ "Income",
"education"      ~ "Education"
)
) %>%
ggplot(aes(x=estimate, y=reorder(term, estimate), color=sig)) +
geom_vline(xintercept=0, linetype="dashed", color="#888") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high), size=0.7) +
scale_color_manual(values=c("FALSE"="#95a5a6","TRUE"="#c0392b"),
labels=c("Not significant","Significant (p<0.05)"), name=NULL) +
facet_wrap(~model, scales="free_x", ncol=1) +
labs(x="Coefficient", y=NULL,
title="Threat Perception and Political Ideology — Three Models",
subtitle="CES 2019 | OLS regression") +
theme_minimal(base_size=12) +
theme(plot.title=element_text(face="bold"),
legend.position="bottom",
strip.text=element_text(face="bold", size=11))
ggsave("three_model_plot.png", width=9, height=10, dpi=300)
cat("Saved: three_model_plot.png\n")
cat("Gender values:\n")
print(table(as.numeric(ces$cps19_gender), useNA="always"))
cat("\nAge summary:\n")
print(summary(df3$age))
library(dplyr)
library(ggplot2)
library(broom)
# Add gender and age group to df3
df3 <- df3 %>%
mutate(
gender = case_when(
as.numeric(cps19_gender) == 1 ~ "Man",
as.numeric(cps19_gender) == 2 ~ "Woman",
TRUE ~ NA_character_
),
age_group = case_when(
age < 35          ~ "18–34",
age >= 35 & age < 50 ~ "35–49",
age >= 50 & age < 65 ~ "50–64",
age >= 65         ~ "65+"
),
age_group = factor(age_group, levels=c("18–34","35–49","50–64","65+"))
)
# ── Plot 1: Mean threat by gender ─────────────────────────────────────────────
p1 <- df3 %>%
filter(!is.na(gender)) %>%
group_by(gender) %>%
summarise(
cultural  = mean(cultural_index, na.rm=TRUE),
economic  = mean(economic_index, na.rm=TRUE),
security  = mean(security_index, na.rm=TRUE),
populist  = mean(populist_index, na.rm=TRUE),
.groups = "drop"
) %>%
tidyr::pivot_longer(cols=c(cultural,economic,security,populist),
names_to="domain", values_to="mean_score") %>%
mutate(domain = case_match(domain,
"cultural" ~ "Cultural", "economic" ~ "Economic",
"security" ~ "Security", "populist" ~ "Populist"
))
ggplot(p1, aes(x=domain, y=mean_score, fill=gender)) +
geom_col(position="dodge", width=0.6) +
geom_text(aes(label=round(mean_score,2)),
position=position_dodge(0.6), vjust=-0.4, size=3.5, color="#333") +
scale_fill_manual(values=c("Man"="#1A4782","Woman"="#C0392B"), name=NULL) +
scale_y_continuous(limits=c(0,5), expand=expansion(mult=c(0,0.1))) +
labs(x=NULL, y="Mean Threat Score (1–5)",
title="Mean Threat Perception by Gender",
subtitle="CES 2019 | 1 = low threat, 5 = high threat",
caption="Cultural: minorities adapt + culture harmed. Economic: immigrants bad for economy.\nSecurity: immigrants increase crime. Populist: majority over minority rights.") +
theme_minimal(base_size=13) +
theme(plot.title=element_text(face="bold"),
panel.grid.major.x=element_blank(),
legend.position="bottom")
ggsave("threat_by_gender.png", width=8, height=5, dpi=300)
cat("Saved: threat_by_gender.png\n")
# ── Plot 2: Mean threat by age group ──────────────────────────────────────────
p2 <- df3 %>%
filter(!is.na(age_group)) %>%
group_by(age_group) %>%
summarise(
cultural  = mean(cultural_index, na.rm=TRUE),
economic  = mean(economic_index, na.rm=TRUE),
security  = mean(security_index, na.rm=TRUE),
populist  = mean(populist_index, na.rm=TRUE),
.groups = "drop"
) %>%
tidyr::pivot_longer(cols=c(cultural,economic,security,populist),
names_to="domain", values_to="mean_score") %>%
mutate(domain = case_match(domain,
"cultural" ~ "Cultural", "economic" ~ "Economic",
"security" ~ "Security", "populist" ~ "Populist"
))
ggplot(p2, aes(x=age_group, y=mean_score, fill=domain)) +
geom_col(position="dodge", width=0.7) +
scale_fill_manual(values=c(
"Cultural"="#1A4782","Economic"="#C0392B",
"Security"="#E8A838","Populist"="#5D4037"), name="Threat Domain") +
scale_y_continuous(limits=c(0,5), expand=expansion(mult=c(0,0.1))) +
labs(x="Age Group", y="Mean Threat Score (1–5)",
title="Mean Threat Perception by Age Group",
subtitle="CES 2019 | 1 = low threat, 5 = high threat") +
theme_minimal(base_size=13) +
theme(plot.title=element_text(face="bold"),
panel.grid.major.x=element_blank(),
legend.position="bottom")
ggsave("threat_by_age.png", width=8, height=5, dpi=300)
cat("Saved: threat_by_age.png\n")
# ── Plot 3: Threat effect by gender (separate regressions) ────────────────────
coef_gender <- bind_rows(
df3 %>% filter(gender=="Man") %>%
lm(ideology ~ cultural_index + populist_index + economic_index + security_index + age + income, data=.) %>%
broom::tidy(conf.int=TRUE) %>% mutate(group="Men"),
df3 %>% filter(gender=="Woman") %>%
lm(ideology ~ cultural_index + populist_index + economic_index + security_index + age + income, data=.) %>%
broom::tidy(conf.int=TRUE) %>% mutate(group="Women")
) %>%
filter(!term %in% c("(Intercept)")) %>%
mutate(
term = case_match(term,
"cultural_index" ~ "Cultural Threat",
"economic_index" ~ "Economic Threat",
"security_index" ~ "Security Threat",
"populist_index" ~ "Populist Threat",
"age"            ~ "Age",
"income"         ~ "Income"
),
sig = p.value < 0.05
)
ggplot(coef_gender, aes(x=estimate, y=reorder(term, estimate), color=group, shape=sig)) +
geom_vline(xintercept=0, linetype="dashed", color="#888") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high), size=0.7,
position=position_dodge(0.5)) +
scale_color_manual(values=c("Men"="#1A4782","Women"="#C0392B"), name=NULL) +
scale_shape_manual(values=c("TRUE"=16,"FALSE"=1),
labels=c("Significant","Not significant"), name=NULL) +
labs(x="Coefficient (effect on ideology, 0=left to 10=right)",
y=NULL,
title="Threat Effect on Ideology by Gender",
subtitle="CES 2019 | Solid = significant (p<0.05), Open = not significant") +
theme_minimal(base_size=13) +
theme(plot.title=element_text(face="bold"), legend.position="bottom")
ggsave("threat_effect_gender.png", width=9, height=6, dpi=300)
cat("Saved: threat_effect_gender.png\n")
# ── Plot 4: Threat effect by age group (separate regressions) ─────────────────
coef_age <- bind_rows(
df3 %>% filter(age_group=="18–34") %>%
lm(ideology ~ cultural_index + populist_index + economic_index + security_index + income, data=.) %>%
broom::tidy(conf.int=TRUE) %>% mutate(group="18–34"),
df3 %>% filter(age_group=="35–49") %>%
lm(ideology ~ cultural_index + populist_index + economic_index + security_index + income, data=.) %>%
broom::tidy(conf.int=TRUE) %>% mutate(group="35–49"),
df3 %>% filter(age_group=="50–64") %>%
lm(ideology ~ cultural_index + populist_index + economic_index + security_index + income, data=.) %>%
broom::tidy(conf.int=TRUE) %>% mutate(group="50–64"),
df3 %>% filter(age_group=="65+") %>%
lm(ideology ~ cultural_index + populist_index + economic_index + security_index + income, data=.) %>%
broom::tidy(conf.int=TRUE) %>% mutate(group="65+")
) %>%
filter(!term %in% c("(Intercept)")) %>%
mutate(
term = case_match(term,
"cultural_index" ~ "Cultural Threat",
"economic_index" ~ "Economic Threat",
"security_index" ~ "Security Threat",
"populist_index" ~ "Populist Threat",
"income"         ~ "Income"
),
sig = p.value < 0.05,
group = factor(group, levels=c("18–34","35–49","50–64","65+"))
)
ggplot(coef_age, aes(x=estimate, y=reorder(term, estimate), color=group, shape=sig)) +
geom_vline(xintercept=0, linetype="dashed", color="#888") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high), size=0.6,
position=position_dodge(0.6)) +
scale_color_manual(values=c(
"18–34"="#1A4782","35–49"="#C0392B",
"50–64"="#E8A838","65+"="#2ECC71"), name="Age Group") +
scale_shape_manual(values=c("TRUE"=16,"FALSE"=1),
labels=c("Significant","Not significant"), name=NULL) +
labs(x="Coefficient (effect on ideology, 0=left to 10=right)",
y=NULL,
title="Threat Effect on Ideology by Age Group",
subtitle="CES 2019 | Solid = significant (p<0.05), Open = not significant") +
theme_minimal(base_size=13) +
theme(plot.title=element_text(face="bold"), legend.position="bottom")
ggsave("threat_effect_age.png", width=9, height=6, dpi=300)
cat("Saved: threat_effect_age.png\n")
