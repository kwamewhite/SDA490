"populist_index"  ~ "Populist Threat\n(majority will over\nminority rights)",
"age"             ~ "Age",
"income"          ~ "Income",
"education"       ~ "Education"
),
sig = p.value < 0.05
)
ggplot(coef_data, aes(x=estimate, y=reorder(label, estimate), color=sig)) +
geom_vline(xintercept=0, linetype="dashed", color="#888") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high), size=0.8) +
scale_color_manual(values=c("FALSE"="#95a5a6","TRUE"="#c0392b"),
labels=c("Not significant","Significant (p<0.05)"),
name=NULL) +
labs(x="Coefficient (effect on ideology, 0=left to 10=right)",
y=NULL,
title="What Predicts Right-Wing Ideology in Canada?",
subtitle="CES 2019 | OLS regression | Controlling for age, income, education") +
theme_minimal(base_size=13) +
theme(plot.title=element_text(face="bold"),
legend.position="bottom")
ggsave("ces_coefficient_plot_final2.png", width=9, height=6, dpi=300)
cat("Saved: ces_coefficient_plot_final2.png\n")
cat(attr(ces$cps19_province, "label"), "\n")
print(table(as.numeric(ces$cps19_province), useNA="always"))
print(attr(ces$cps19_province, "labels"))
cat(attr(ces$cps19_votechoice, "label"), "\n")
print(attr(ces$cps19_votechoice, "labels"))
prov_labels <- c(
"14"="Alberta", "15"="British Columbia", "16"="Manitoba",
"17"="New Brunswick", "18"="Newfoundland and Labrador",
"19"="Northwest Territories", "20"="Nova Scotia", "21"="Nunavut",
"22"="Ontario", "23"="Prince Edward Island", "24"="Quebec",
"25"="Saskatchewan", "26"="Yukon"
)
ces_prov <- ces %>%
mutate(
province = prov_labels[as.character(as.numeric(cps19_province))],
nav1 = as.numeric(pes19_nativism1),
nav2 = as.numeric(pes19_nativism2),
nav3 = as.numeric(pes19_nativism3),
nav4 = as.numeric(pes19_nativism4),
nav5 = as.numeric(pes19_nativism5),
across(c(nav1,nav2,nav3,nav4,nav5), ~ifelse(.x == 6, NA, .x)),
nav3_r = 6 - nav3,
cultural_index  = rowMeans(cbind(nav1, nav4), na.rm=TRUE),
security_index  = nav5,
economic_index  = nav3_r,
populist_index  = nav2,
vote = as.numeric(cps19_votechoice)
) %>%
filter(!is.na(province), !is.na(cultural_index))
cat("n =", nrow(ces_prov), "\n")
ces_prov %>%
group_by(province) %>%
summarise(
mean_cultural = mean(cultural_index, na.rm=TRUE),
n = n()
) %>%
arrange(desc(mean_cultural)) %>%
print()
cat(attr(ces$cps19_votechoice, "labels"), "\n")
table(as.numeric(ces_prov$vote), useNA="always")
